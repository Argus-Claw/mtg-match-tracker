<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a1a35"/>
      <stop offset="100%" style="stop-color:#0a0a1a"/>
    </linearGradient>
    <linearGradient id="sword" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#818cf8"/>
      <stop offset="100%" style="stop-color:#6366f1"/>
    </linearGradient>
  </defs>
  <rect width="512" height="512" rx="96" fill="url(#bg)"/>
  <!-- Left sword -->
  <g transform="translate(256,256) rotate(-30)">
    <rect x="-8" y="-120" width="16" height="180" rx="4" fill="url(#sword)"/>
    <rect x="-28" y="50" width="56" height="12" rx="4" fill="#a5b4fc"/>
    <rect x="-6" y="60" width="12" height="40" rx="3" fill="#7c3aed"/>
  </g>
  <!-- Right sword -->
  <g transform="translate(256,256) rotate(30)">
    <rect x="-8" y="-120" width="16" height="180" rx="4" fill="url(#sword)"/>
    <rect x="-28" y="50" width="56" height="12" rx="4" fill="#a5b4fc"/>
    <rect x="-6" y="60" width="12" height="40" rx="3" fill="#7c3aed"/>
  </g>
  <!-- Shield / center pip -->
  <circle cx="256" cy="230" r="28" fill="#1e1b4b" stroke="#818cf8" stroke-width="3"/>
  <text x="256" y="240" text-anchor="middle" font-size="28" font-weight="bold" fill="#818cf8" font-family="serif">M</text>
</svg>
